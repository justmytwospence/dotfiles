# Font
font-family = Hack
font-size = 14

# Theme (auto-switches with macOS dark/light mode)
theme = light:custom-light,dark:custom-dark

# Shell integration
shell-integration-features = cursor,sudo,ssh-terminfo
link-url = true

# macOS
macos-titlebar-style = tabs
macos-option-as-alt = true
macos-non-native-fullscreen = visible-menu
desktop-notifications = true
bell-features = system

# Clipboard (enable OSC 52 for tmux integration)
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true

# Font rendering
font-thicken = true

# Window state
window-save-state = never
window-inherit-working-directory = false

# Window
window-padding-x = 8
window-padding-y = 4

# Transparency (use non-native fullscreen to preserve this)
background-opacity = 0.92

# Cursor (block cursor, no blink -- vim style)
cursor-style = block
cursor-style-blink = false

# Scrollback (generous for Claude Code output)
scrollback-limit = 100000

# Mouse
mouse-hide-while-typing = true
copy-on-select = clipboard

# Splits
unfocused-split-opacity = 0.85
split-divider-color = #6699ff


# Fullscreen
keybind = cmd+enter=toggle_fullscreen

# Quick terminal (summon from anywhere)
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Don't prompt when closing a pane
confirm-close-surface = false

# tmux-like key table (ctrl+b prefix)
keybind = ctrl+b=activate_key_table:tmux

# bind-key & kill-window
keybind = tmux/shift+digit_7=close_tab
keybind = chain=deactivate_key_table
# bind-key x kill-pane
keybind = tmux/x=close_surface
keybind = chain=deactivate_key_table

# bind-key -r '<' swap-window -dt -1
# bind-key -r '>' swap-window -dt +1
keybind = tmux/shift+comma=move_tab:-1
keybind = chain=deactivate_key_table
keybind = tmux/shift+period=move_tab:1
keybind = chain=deactivate_key_table

# bind-key -r C-n next-window (repeatable)
# bind-key -r C-p previous-window (repeatable)
# bind-key -r C-o select-pane -t :.+ (repeatable)
# bind-key -r Space next-layout (repeatable)
keybind = tmux/ctrl+n=next_tab
keybind = tmux/ctrl+p=previous_tab
keybind = tmux/ctrl+o=goto_split:next
keybind = tmux/space=equalize_splits

# bind-key c new-window
keybind = tmux/c=new_tab
keybind = chain=deactivate_key_table

# bind-key % split-window (new pane below)
# bind-key '"' split-window -h (new pane right)
keybind = tmux/shift+digit_5=new_split:down
keybind = chain=deactivate_key_table
keybind = tmux/shift+quote=new_split:right
keybind = chain=deactivate_key_table

# bind-key -r C-h resize-pane -L 5 (repeatable)
# bind-key -r C-j resize-pane -D 5 (repeatable)
# bind-key -r C-k resize-pane -U 5 (repeatable)
# bind-key -r C-l resize-pane -R 5 (repeatable)
keybind = tmux/ctrl+h=resize_split:left,10
keybind = tmux/ctrl+j=resize_split:down,10
keybind = tmux/ctrl+k=resize_split:up,10
keybind = tmux/ctrl+l=resize_split:right,10

# bind-key h select-pane -L
# bind-key j select-pane -D
# bind-key k select-pane -U
# bind-key l select-pane -R
keybind = tmux/h=goto_split:left
keybind = chain=deactivate_key_table
keybind = tmux/j=goto_split:down
keybind = chain=deactivate_key_table
keybind = tmux/k=goto_split:up
keybind = chain=deactivate_key_table
keybind = tmux/l=goto_split:right
keybind = chain=deactivate_key_table

# Exit key table (escape or ctrl+b again)
keybind = tmux/escape=deactivate_key_table
