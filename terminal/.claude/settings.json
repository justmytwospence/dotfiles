{
  "statusLine": {
    "type": "command",
    "command": "bash /Users/spencerboucher/.claude/statusline-command.sh"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "command": "TTY=$(tmux display-message -p '#{pane_tty}' 2>/dev/null || echo /dev/tty); printf '\\a' > \"$TTY\" 2>/dev/null; tmux display-message ' Claude ready' 2>/dev/null || true"
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git cherry-pick:*)",

      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(pwd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(id:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(date:*)",
      "Bash(man:*)",
      "Bash(sw_vers:*)",

      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(bat:*)",
      "Bash(eza:*)",
      "Bash(jq:*)",
      "Bash(delta:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",

      "Bash(defaults read:*)",
      "Bash(plutil:*)",
      "Bash(claude config:*)",

      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(npm list:*)",
      "Bash(npm info:*)",
      "Bash(npm root:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(python --version:*)",
      "Bash(python3 --version:*)",
      "Bash(python -m:*)",
      "Bash(python3 -m:*)",
      "Bash(pytest:*)",
      "Bash(make:*)",
      "Bash(node --version:*)",
      "Bash(ruby --version:*)",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:man.archlinux.org)",
      "WebFetch(domain:wiki.archlinux.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:developer.apple.com)",
      "WebFetch(domain:docs.brew.sh)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:claudefa.st)"
    ]
  }
}
