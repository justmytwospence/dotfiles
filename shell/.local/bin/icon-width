#!/usr/bin/env python3
"""icon-width: report the TRUE rendered cell width of each glyph in THIS terminal.

Claude Code's statusline renderer measures your line with wcwidth, which counts
most symbols and Private-Use-Area (Nerd Font) glyphs as 1 cell. If your terminal
actually draws one as 2, the statusline can occupy a row Claude Code didn't
budget for -> stale artifacts that only a ^L repaint clears.

Run this INSIDE the same terminal + multiplexer you run Claude Code in (it queries
the cursor, so it must talk to the real tty). Keep glyphs that report width 1, or
budget each at the width shown (the statusline's ICON_W must match reality).

  icon-width                 # measure the default statusline glyph set
  icon-width "⎇░█→●★"        # measure the glyphs you pass
"""
import sys, os, termios, tty

# Default = the icons + bar cells used by statusline-command.sh
DEFAULT = "\U000F06A9\U000F024B\U0000E725\U000F0150\U000F035B\U000F0954\U000F03D7" "░█"


def cell_width(ch):
    """Advance from column 1, print the glyph, ask the terminal where the cursor
    landed (CSI 6n -> ESC [ row ; col R). col-1 == cells the glyph advanced."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        os.write(1, b"\r" + ch.encode() + b"\x1b[6n")
        buf = b""
        while not buf.endswith(b"R"):
            buf += os.read(fd, 1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    os.write(1, b"\r\x1b[K")  # wipe the probe glyph off the line
    return int(buf.decode().split("[")[1].rstrip("R").split(";")[1]) - 1


def main():
    if not sys.stdin.isatty():
        sys.exit("icon-width: run me in an interactive terminal (I query the cursor)")
    glyphs = sys.argv[1] if len(sys.argv) > 1 else DEFAULT
    for ch in glyphs:
        w = cell_width(ch)
        note = "" if w == 1 else f"   <- {w} cells: tear risk unless ICON_W={w}"
        print(f"U+{ord(ch):05X}  {ch}  width={w}{note}")


if __name__ == "__main__":
    main()
