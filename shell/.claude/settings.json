{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(pwd:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(id:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(date:*)",
      "Bash(man:*)",
      "Bash(sw_vers:*)",
      "Bash(bat:*)",
      "Bash(eza:*)",
      "Bash(jq:*)",
      "Bash(delta:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",
      "Bash(defaults read:*)",
      "Bash(plutil:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(npm list:*)",
      "Bash(npm info:*)",
      "Bash(npm root:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(python --version:*)",
      "Bash(python3 --version:*)",
      "Bash(python -m:*)",
      "Bash(python3 -m:*)",
      "Bash(pytest:*)",
      "Bash(make:*)",
      "Bash(node --version:*)",
      "Bash(ruby --version:*)",
      "Bash(cmux:*)",
      "Bash(npx skills:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.python.org)",
      "Read(/**)",
      "Read(~/.claude/**)",
      "Glob(/**)",
      "Glob(~/.claude/**)",
      "Grep(/**)",
      "Grep(~/.claude/**)",
      "mcp__obsidian__read_note",
      "mcp__obsidian__read_multiple_notes",
      "mcp__obsidian__list_directory",
      "mcp__obsidian__search_notes",
      "mcp__obsidian__get_notes_info",
      "mcp__obsidian__get_frontmatter",
      "mcp__obsidian__get_vault_stats"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "medium",
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  }
}
