{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bat:*)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(brew search:*)",
      "Bash(chmod +x:*)",
      "Bash(claude config:*)",
      "Bash(cmux:*)",
      "Bash(date:*)",
      "Bash(defaults read:*)",
      "Bash(delta:*)",
      "Bash(df:*)",
      "Bash(diff:*)",
      "Bash(dig:*)",
      "Bash(du:*)",
      "Bash(env:*)",
      "Bash(eza:*)",
      "Bash(file:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ghostty +list-themes:*)",
      "Bash(ghostty +show-config:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(git tag:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(make:*)",
      "Bash(man:*)",
      "Bash(node --version:*)",
      "Bash(npm info:*)",
      "Bash(npm list:*)",
      "Bash(npm root:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx skills:*)",
      "Bash(open:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(plutil:*)",
      "Bash(printenv:*)",
      "Bash(ps:*)",
      "Bash(pwd:*)",
      "Bash(pytest:*)",
      "Bash(python --version:*)",
      "Bash(python -m:*)",
      "Bash(python3 --version:*)",
      "Bash(python3 -m:*)",
      "Bash(realpath:*)",
      "Bash(ruby --version:*)",
      "Bash(stow:*)",
      "Bash(sw_vers:*)",
      "Bash(tree:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Glob(/**)",
      "Glob(~/.claude/**)",
      "Grep(/**)",
      "Grep(~/.claude/**)",
      "Read(/**)",
      "Read(~/.claude/**)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.brew.sh)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:man.archlinux.org)",
      "WebFetch(domain:wiki.archlinux.org)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/save-plan-to-obsidian.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
