{
  "env": {
    "CLAUDE_CODE_ALT_SCREEN_FULL_REPAINT": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bat:*)",
      "Bash(bd:*)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(brew search:*)",
      "Bash(chmod +x:*)",
      "Bash(claude config:*)",
      "Bash(cmux:*)",
      "Bash(date:*)",
      "Bash(defaults read:*)",
      "Bash(delta:*)",
      "Bash(df:*)",
      "Bash(diff:*)",
      "Bash(dig:*)",
      "Bash(du:*)",
      "Bash(env:*)",
      "Bash(eza:*)",
      "Bash(file:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(git tag:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(make:*)",
      "Bash(man:*)",
      "Bash(node --version:*)",
      "Bash(npm info:*)",
      "Bash(npm list:*)",
      "Bash(npm root:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx skills:*)",
      "Bash(open:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(plutil:*)",
      "Bash(printenv:*)",
      "Bash(ps:*)",
      "Bash(pwd:*)",
      "Bash(pytest:*)",
      "Bash(python --version:*)",
      "Bash(python3 --version:*)",
      "Bash(realpath:*)",
      "Bash(ruby --version:*)",
      "Bash(sw_vers:*)",
      "Bash(tree:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Glob(/**)",
      "Glob(~/.claude/**)",
      "Grep(/**)",
      "Grep(~/.claude/**)",
      "Read(/**)",
      "Read(~/.claude/**)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:docs.astral.sh)",
      "WebSearch",
      "Bash(claude help:*)",
      "Bash(claude mcp:*)",
      "Bash(claude skills:*)",
      "Bash(npm config:*)",
      "Bash(npm help:*)",
      "Bash(sed:*)",
      "Bash(uv help:*)",
      "Bash(uv settings:*)",
      "mcp__obsidian__*",
      "Skill(update-config)",
      "Bash(uv pip *)",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/save-plan-to-obsidian.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/clear-tmux-waiting.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/clear-tmux-waiting.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/spencerboucher/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/clear-tmux-waiting.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
